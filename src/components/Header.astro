---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="nav-shell" aria-label="Main navigation">
		<div class="brand-block">
			<a href="/" class="brand">
				<span class="brand-mark" aria-hidden="true"></span>
				<span class="brand-text">
					<span class="brand-label">Journal</span>
					<span class="brand-name">{SITE_TITLE}</span>
				</span>
			</a>
		</div>

		<div class="nav-links desktop-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/work">Work</HeaderLink>
		</div>

		<details class="mobile-nav">
			<summary class="mobile-trigger" aria-label="Toggle navigation">
				<span class="mobile-trigger-text">Menu</span>
				<span class="mobile-trigger-icon" aria-hidden="true">
					<span></span>
					<span></span>
				</span>
			</summary>

			<div class="mobile-panel">
				<div class="mobile-panel-links">
					<HeaderLink href="/">Home</HeaderLink>
					<HeaderLink href="/blog">Blog</HeaderLink>
					<HeaderLink href="/about">About</HeaderLink>
				</div>
			</div>
		</details>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 18px 18px 0;
		pointer-events: none;
	}

	.nav-shell {
		position: relative;
		width: min(1280px, 100%);
		margin: 0 auto;
		padding: 12px 14px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.34);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		border: 1px solid rgba(255, 255, 255, 0.58);
		box-shadow:
			0 10px 30px rgba(29, 40, 34, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.45);
		pointer-events: auto;
	}

	.brand-block {
		min-width: 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.9rem;
		min-width: 0;
		text-decoration: none;
		color: inherit;
	}

	.brand-mark {
		width: 10px;
		height: 10px;
		border-radius: 999px;
		flex-shrink: 0;
		background:
			radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.2) 45%, transparent 46%),
			#7ea38c;
		box-shadow:
			0 0 0 6px rgba(126, 163, 140, 0.08),
			0 6px 20px rgba(126, 163, 140, 0.3);
	}

	.brand-text {
		display: flex;
		flex-direction: column;
		min-width: 0;
		line-height: 1;
	}

	.brand-label {
		margin-bottom: 0.22rem;
		font-size: 0.62rem;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: rgba(33, 48, 40, 0.46);
	}

	.brand-name {
		font-size: 0.95rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		color: rgba(33, 48, 40, 0.92);
		white-space: nowrap;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.nav-links :global(a) {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.72rem 1rem;
		border-radius: 999px;
		border: 1px solid transparent;
		color: rgba(33, 48, 40, 0.72);
		font-size: 0.76rem;
		font-weight: 500;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		text-decoration: none;
		transition:
			color 0.35s ease,
			background 0.35s ease,
			border-color 0.35s ease,
			transform 0.35s ease,
			box-shadow 0.35s ease;
	}

	.nav-links :global(a:hover) {
		color: rgba(33, 48, 40, 0.95);
		background: rgba(255, 255, 255, 0.46);
		border-color: rgba(255, 255, 255, 0.64);
		transform: translateY(-1px);
		box-shadow: 0 10px 24px rgba(29, 40, 34, 0.06);
	}

	.nav-links :global(a.active) {
		color: #213028;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.38));
		border-color: rgba(126, 163, 140, 0.18);
		box-shadow:
			0 10px 24px rgba(29, 40, 34, 0.06),
			inset 0 1px 0 rgba(255, 255, 255, 0.62);
	}

	.nav-links :global(a.active::after) {
		content: '';
		width: 6px;
		height: 6px;
		margin-left: 0.55rem;
		border-radius: 999px;
		background: #7ea38c;
		box-shadow: 0 0 0 4px rgba(126, 163, 140, 0.08);
	}

	.mobile-nav {
		display: none;
		position: relative;
	}

	.mobile-trigger {
		list-style: none;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.72rem 0.95rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.56);
		background: rgba(255, 255, 255, 0.42);
		box-shadow:
			0 10px 24px rgba(29, 40, 34, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.52);
		cursor: pointer;
		user-select: none;
		transition:
			background 0.35s ease,
			border-color 0.35s ease,
			transform 0.35s ease,
			box-shadow 0.35s ease;
	}

	.mobile-trigger::-webkit-details-marker {
		display: none;
	}

	.mobile-trigger:hover {
		transform: translateY(-1px);
		background: rgba(255, 255, 255, 0.5);
		border-color: rgba(255, 255, 255, 0.66);
	}

	.mobile-trigger-text {
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: rgba(33, 48, 40, 0.8);
	}

	.mobile-trigger-icon {
		position: relative;
		width: 16px;
		height: 12px;
		display: inline-flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.mobile-trigger-icon span {
		display: block;
		width: 100%;
		height: 1.5px;
		border-radius: 999px;
		background: rgba(33, 48, 40, 0.74);
		transition: transform 0.3s ease, opacity 0.3s ease;
	}

	.mobile-nav[open] .mobile-trigger-icon span:first-child {
		transform: translateY(5px) rotate(45deg);
	}

	.mobile-nav[open] .mobile-trigger-icon span:last-child {
		transform: translateY(-5px) rotate(-45deg);
	}

	.mobile-panel {
		position: absolute;
		top: calc(100% + 10px);
		right: 0;
		width: min(240px, calc(100vw - 24px));
		padding: 10px;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.4);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border: 1px solid rgba(255, 255, 255, 0.58);
		box-shadow:
			0 18px 44px rgba(29, 40, 34, 0.09),
			inset 0 1px 0 rgba(255, 255, 255, 0.5);
	}

	.mobile-panel-links {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.mobile-panel-links :global(a) {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.88rem 0.95rem;
		border-radius: 16px;
		border: 1px solid transparent;
		color: rgba(33, 48, 40, 0.76);
		font-size: 0.74rem;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.16);
		transition:
			background 0.3s ease,
			border-color 0.3s ease,
			transform 0.3s ease,
			box-shadow 0.3s ease,
			color 0.3s ease;
	}

	.mobile-panel-links :global(a:hover) {
		color: rgba(33, 48, 40, 0.95);
		background: rgba(255, 255, 255, 0.5);
		border-color: rgba(255, 255, 255, 0.66);
		transform: translateY(-1px);
		box-shadow: 0 10px 24px rgba(29, 40, 34, 0.05);
	}

	.mobile-panel-links :global(a.active) {
		color: #213028;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.46));
		border-color: rgba(126, 163, 140, 0.18);
		box-shadow:
			0 10px 24px rgba(29, 40, 34, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.62);
	}

	.mobile-panel-links :global(a.active::after) {
		content: '';
		width: 6px;
		height: 6px;
		border-radius: 999px;
		background: #7ea38c;
		box-shadow: 0 0 0 4px rgba(126, 163, 140, 0.08);
	}

	@media (max-width: 760px) {
		.site-header {
			padding: 12px 12px 0;
		}

		.nav-shell {
			padding: 10px 12px;
			border-radius: 999px;
			gap: 0.75rem;
		}

		.desktop-links {
			display: none;
		}

		.mobile-nav {
			display: block;
			margin-left: auto;
		}

		.brand {
			gap: 0.72rem;
		}

		.brand-mark {
			width: 9px;
			height: 9px;
			box-shadow:
				0 0 0 5px rgba(126, 163, 140, 0.08),
				0 5px 16px rgba(126, 163, 140, 0.24);
		}

		.brand-label {
			margin-bottom: 0.16rem;
			font-size: 0.56rem;
			letter-spacing: 0.22em;
		}

		.brand-name {
			font-size: 0.88rem;
			letter-spacing: 0.05em;
		}
	}

	@media (max-width: 420px) {
		.site-header {
			padding: 10px 10px 0;
		}

		.nav-shell {
			padding: 9px 10px;
		}

		.brand {
			gap: 0.65rem;
		}

		.brand-label {
			font-size: 0.52rem;
			letter-spacing: 0.18em;
		}

		.brand-name {
			font-size: 0.82rem;
		}

		.mobile-trigger {
			padding: 0.68rem 0.85rem;
		}

		.mobile-trigger-text {
			font-size: 0.68rem;
			letter-spacing: 0.18em;
		}

		.mobile-panel {
			width: min(220px, calc(100vw - 20px));
			padding: 8px;
			border-radius: 20px;
		}

		.mobile-panel-links :global(a) {
			padding: 0.82rem 0.88rem;
			font-size: 0.7rem;
			letter-spacing: 0.14em;
		}
	}
</style>