---
// src/pages/index.astro
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>明天，你好 | Hello Tomorrow</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;700&family=Outfit:wght@100;200;300;400&display=swap" rel="stylesheet">
</head>
<body>
  
  <div class="page-wrapper">
    
    <div class="ambient-background">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <div class="watermark-text fade-in slow-pan">TOMORROW</div>

    <div class="editorial-container">
      
      <header class="top-bar fade-in">
        <div class="logo group">
           <span class="logo-mark"></span> OASIS.
        </div>
        <div class="date-display">APRIL, 2026</div>
      </header>

      <main class="art-layout">
        <section class="visual-left">
          <h2 class="pre-title slide-up delay-1">Chapter. Tomorrow</h2>
          <div class="title-group">
            <h1 class="main-title slide-up delay-2">明天<span class="comma">，</span><br/><span class="indent">你好</span><span class="accent-dot">.</span></h1>
            
            <div class="vertical-quote slide-up delay-3">
              <p>含着泪微笑。</p>
              <p>越美好，越害怕得到。</p>
            </div>
          </div>
        </section>

        <section class="lyrics-right">
          <div class="lyric-staircase">
            <div class="slide-up delay-4 step-1"><p class="float-anim float-delay-1">长大以后，我只能奔跑</p></div>
            <div class="slide-up delay-5 step-2"><p class="float-anim float-delay-2">我多害怕，黑暗中跌倒</p></div>
            <div class="slide-up delay-6 step-3"><p class="float-anim float-delay-3">每一次哭，又笑着奔跑</p></div>
            <div class="slide-up delay-7 step-4"><p class="float-anim float-delay-1">一边失去，一边在寻找</p></div>
            
            <div class="slide-up delay-8 step-5">
              <div class="highlight-block float-anim float-delay-2">
                <div class="decorative-line"></div>
                <p>声音多渺小，却提醒我</p>
                <p class="strong">勇敢是什么。</p>
              </div>
            </div>
          </div>
        </section>
      </main>

	<footer class="bottom-bar slide-up delay-9">
			<div class="music-widget">
			<div class="vinyl-wrapper spin-anim" id="vinyl">
				<button class="play-circle" id="play-btn" aria-label="Play Track">
				<svg id="play-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
				<svg id="pause-icon" viewBox="0 0 24 24" fill="currentColor" style="display: none;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
				</button>
			</div>
			<div class="track-details">
				<span class="track-name">明天，你好</span>
				<div class="eq-visualizer" id="eq">
				<span class="bar"></span><span class="bar"></span><span class="bar"></span><span class="bar"></span>
				</div>
			</div>
			</div>

			<audio id="bg-music" loop>
			<source src="/music/hello.mp3" type="audio/mpeg">
			您的浏览器不支持音频元素。
			</audio>

			<a href="/blog" class="enter-link group">
			<span class="link-text">blog
			</span>
			<div class="arrow-box">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
			</div>
			</a>
		</footer>

    </div>
  </div>
</body>
</html>

<style>
  :global(html), :global(body) {
    margin: 0 !important;
    padding: 0 !important;
    background-color: #f4f7f5 !important; 
    overflow-x: hidden;
  }

  .page-wrapper {
    width: 100vw;
    min-height: 100vh;
    color: #2a3b32;
    font-family: 'Outfit', system-ui, sans-serif;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  /* ========== 艺术化背景与环境光 ========== */
  .ambient-background {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 0;
    overflow: hidden;
    filter: blur(80px);
    opacity: 0.6;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    animation: drift 20s infinite alternate ease-in-out;
  }

  .orb-1 { width: 40vw; height: 40vw; background: rgba(126, 163, 140, 0.3); top: -10%; left: -10%; }
  .orb-2 { width: 50vw; height: 50vw; background: rgba(240, 230, 200, 0.4); bottom: -20%; right: -10%; animation-delay: -5s; }
  .orb-3 { width: 30vw; height: 30vw; background: rgba(179, 204, 190, 0.4); top: 40%; left: 40%; animation-duration: 25s; }

  .watermark-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 25vw;
    font-weight: 100;
    color: rgba(126, 163, 140, 0.04);
    z-index: 0;
    pointer-events: none;
    letter-spacing: -2px;
    white-space: nowrap;
  }

  /* ========== 页面框架 ========== */
  .editorial-container {
    width: 100%;
    max-width: 1200px;
    height: 90vh;
    min-height: 750px;
    padding: 2.5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    z-index: 1;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.02);
    margin: 2rem;
  }

  /* ========== 顶部 ========== */
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(126, 163, 140, 0.2);
    padding-bottom: 1.5rem;
  }

  .logo {
    font-weight: 400;
    letter-spacing: 4px;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-mark {
    width: 8px; height: 8px;
    background: #7ea38c;
    border-radius: 50%;
    display: inline-block;
  }

  .date-display {
    font-size: 0.8rem;
    letter-spacing: 2px;
    color: #5a7062;
    font-weight: 300;
  }

  /* ========== 中间错落布局 ========== */
  .art-layout {
    flex: 1;
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 2rem;
    padding: 4rem 0;
  }

  .visual-left {
    flex: 1;
    position: relative;
  }

  .pre-title {
    font-size: 0.85rem;
    letter-spacing: 4px;
    color: #7ea38c;
    text-transform: uppercase;
    margin-bottom: 2rem;
    font-weight: 300;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .pre-title::before {
    content: "";
    width: 40px;
    height: 1px;
    background: #7ea38c;
  }

  .title-group {
    display: flex;
    gap: 3rem;
  }

  .main-title {
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: 300;
    line-height: 1.2;
    margin: 0;
    letter-spacing: 2px;
  }

  .indent { padding-left: 1em; }
  .comma { font-size: 0.5em; opacity: 0.5; }
  .accent-dot { color: #7ea38c; }

  /* 竖排文本 */
  .vertical-quote {
    writing-mode: vertical-rl;
    border-top: 2px solid #7ea38c;
    padding-top: 1.5rem;
    margin-top: 1rem;
  }

  .vertical-quote p {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.2rem;
    color: #5a7062;
    letter-spacing: 4px;
    line-height: 2;
    margin: 0;
    margin-left: 1rem;
  }

  .lyrics-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .lyric-staircase {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .lyric-staircase p {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.15rem;
    color: #4a5c51;
    letter-spacing: 2px;
    margin: 0;
  }

  .step-1 { transform: translateX(0); }
  .step-2 { transform: translateX(30px); }
  .step-3 { transform: translateX(-10px); }
  .step-4 { transform: translateX(20px); }
  .step-5 { transform: translateX(50px); margin-top: 2rem; position: relative; }

  .highlight-block {
    background: rgba(255, 255, 255, 0.7);
    padding: 2rem;
    border-radius: 4px 24px 24px 24px;
    box-shadow: 0 15px 35px -10px rgba(126, 163, 140, 0.15);
    position: relative;
    backdrop-filter: blur(5px);
  }

  .decorative-line {
    position: absolute;
    left: 0; top: 2rem; bottom: 2rem;
    width: 3px;
    background: #7ea38c;
    border-radius: 0 2px 2px 0;
  }

  .highlight-block .strong {
    font-size: 1.5rem;
    font-weight: 500;
    margin-top: 0.8rem;
    color: #7ea38c;
  }

  /* ========== 底部控件 ========== */
  .bottom-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(126, 163, 140, 0.2);
    padding-top: 1.5rem;
  }

  .music-widget {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .vinyl-wrapper {
    padding: 4px;
    border-radius: 50%;
    border: 1px dashed rgba(126, 163, 140, 0.5);
  }

  .play-circle {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: #7ea38c;
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    border: none;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .play-circle svg { width: 20px; height: 20px; transform: translateX(1px); }
  .play-circle:hover { transform: scale(1.1); box-shadow: 0 10px 25px rgba(126, 163, 140, 0.4); }

  .track-details { display: flex; flex-direction: column; gap: 0.4rem; }
  .track-name { font-family: 'Noto Serif SC', serif; font-size: 0.95rem; font-weight: 500; }

  .eq-visualizer { display: flex; gap: 3px; align-items: flex-end; height: 12px; }
  .eq-visualizer .bar {
    width: 2px; background-color: #7ea38c; border-radius: 1px;
    animation: eqBounce 1s infinite alternate ease-in-out;
  }
  .eq-visualizer .bar:nth-child(1) { height: 40%; animation-delay: 0.1s; }
  .eq-visualizer .bar:nth-child(2) { height: 100%; animation-delay: 0.4s; }
  .eq-visualizer .bar:nth-child(3) { height: 60%; animation-delay: 0.2s; }
  .eq-visualizer .bar:nth-child(4) { height: 80%; animation-delay: 0.5s; }

  /* 博客入口 */
  .enter-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: #2a3b32;
    font-family: 'Noto Serif SC', serif;
    font-size: 1.05rem;
    font-weight: 500;
  }

  .arrow-box {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(126, 163, 140, 0.1);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .arrow-box svg { width: 18px; height: 18px; color: #7ea38c; transition: transform 0.4s ease; }

  .enter-link:hover .arrow-box { background: #7ea38c; }
  .enter-link:hover .arrow-box svg { color: white; transform: translateX(3px) rotate(-45deg); }

  /* ========== 动画 ========== */
  @keyframes drift {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(5%, 5%) scale(1.1); }
  }

  @keyframes eqBounce { 0% { transform: scaleY(0.4); } 100% { transform: scaleY(1); } }
  
  .spin-anim { animation: spin 10s linear infinite; }
  @keyframes spin { 100% { transform: rotate(360deg); } }

  /* 持续呼吸悬浮动画 */
  .float-anim { animation: float 6s ease-in-out infinite alternate; }
  .float-delay-1 { animation-delay: 0s; }
  .float-delay-2 { animation-delay: -2s; }
  .float-delay-3 { animation-delay: -4s; }
  
  @keyframes float {
    0% { transform: translateY(0px); }
    100% { transform: translateY(-8px); }
  }

  /* 入场动画 */
  .slow-pan { animation: panBg 20s ease-out forwards; }
  @keyframes panBg { from { transform: translate(-50%, -45%); } to { transform: translate(-50%, -50%); } }

  .fade-in { opacity: 0; animation: fadeInAnim 1s ease-out forwards; }
  @keyframes fadeInAnim { to { opacity: 1; } }

  .slide-up { opacity: 0; animation: slideUpAnim 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
  @keyframes slideUpAnim {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .delay-1 { animation-delay: 0.2s; }
  .delay-2 { animation-delay: 0.4s; }
  .delay-3 { animation-delay: 0.6s; }
  .delay-4 { animation-delay: 0.8s; }
  .delay-5 { animation-delay: 0.9s; }
  .delay-6 { animation-delay: 1.0s; }
  .delay-7 { animation-delay: 1.1s; }
  .delay-8 { animation-delay: 1.3s; }
  .delay-9 { animation-delay: 1.6s; }

  /* ========== 响应式 ========== */
  @media (max-width: 900px) {
    .editorial-container { padding: 2rem; height: auto; margin: 1rem; }
    .art-layout { flex-direction: column; gap: 4rem; padding: 2rem 0; }
    .title-group { flex-direction: column; gap: 2rem; }
    .vertical-quote { writing-mode: horizontal-tb; border-top: none; border-left: 2px solid #7ea38c; padding-top: 0; padding-left: 1.5rem; }
    .vertical-quote p { margin-left: 0; margin-bottom: 0.5rem; letter-spacing: 2px; }
    .lyrics-right { justify-content: flex-start; }
    .step-1, .step-2, .step-3, .step-4, .step-5 { transform: translateX(0); }
    .bottom-bar { flex-direction: column; align-items: flex-start; gap: 2rem; }
    .watermark-text { font-size: 35vw; }
  }
</style>

<script>
  // 等待 DOM 加载完成
  document.addEventListener('DOMContentLoaded', () => {
    const audio = document.getElementById('bg-music');
    const playBtn = document.getElementById('play-btn');
    const playIcon = document.getElementById('play-icon');
    const pauseIcon = document.getElementById('pause-icon');
    const vinyl = document.getElementById('vinyl');
    const eq = document.getElementById('eq');

    // 初始状态：让黑胶唱片和均衡器停止动画
    vinyl.style.animationPlayState = 'paused';
    const eqBars = eq.querySelectorAll('.bar');
    eqBars.forEach(bar => bar.style.animationPlayState = 'paused');

    let isPlaying = false;

    // 点击按钮切换播放/暂停状态
    playBtn.addEventListener('click', () => {
      if (isPlaying) {
        // 暂停音乐
        audio.pause();
        playIcon.style.display = 'block';
        pauseIcon.style.display = 'none';
        
        // 暂停动画
        vinyl.style.animationPlayState = 'paused';
        eqBars.forEach(bar => bar.style.animationPlayState = 'paused');
      } else {
        // 播放音乐
        audio.play();
        playIcon.style.display = 'none';
        pauseIcon.style.display = 'block';
        
        // 恢复动画
        vinyl.style.animationPlayState = 'running';
        eqBars.forEach(bar => bar.style.animationPlayState = 'running');
      }
      isPlaying = !isPlaying;
    });
  });
</script>