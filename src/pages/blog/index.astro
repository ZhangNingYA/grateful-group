---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = posts[0];
const restPosts = posts.slice(1);

const archiveYear = new Date().getFullYear();

const variants = [
	'entry--wide',
	'entry--tall',
	'entry--standard',
	'entry--wide',
	'entry--standard',
	'entry--tall',
	'entry--standard',
	'entry--wide',
];

const getVariant = (index: number) => variants[index % variants.length];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;700&family=Outfit:wght@200;300;400;500;600&display=swap"
			rel="stylesheet"
		/>

		<style>
			:global(html),
			:global(body) {
				margin: 0;
				padding: 0;
				overflow-x: hidden;
				background:
					radial-gradient(circle at 0% 0%, rgba(145, 176, 156, 0.12), transparent 28%),
					radial-gradient(circle at 100% 10%, rgba(225, 215, 189, 0.18), transparent 24%),
					radial-gradient(circle at 50% 100%, rgba(181, 201, 192, 0.14), transparent 20%),
					linear-gradient(180deg, #f7f3ed 0%, #eef3ef 100%);
				color: #213028;
				font-family: 'Outfit', system-ui, sans-serif;
			}

			:global(a) {
				color: inherit;
				text-decoration: none;
			}

			.page {
				position: relative;
				min-height: 100vh;
				padding: 0 18px 42px;
			}

			.bg-shape {
				position: fixed;
				pointer-events: none;
				z-index: 0;
				opacity: 0.55;
				filter: blur(90px);
				border-radius: 999px;
				animation: drift 16s ease-in-out infinite alternate;
			}

			.bg-shape--1 {
				top: -8rem;
				left: -6rem;
				width: 22rem;
				height: 22rem;
				background: rgba(126, 163, 140, 0.22);
			}

			.bg-shape--2 {
				top: 16rem;
				right: -7rem;
				width: 20rem;
				height: 20rem;
				background: rgba(221, 207, 175, 0.28);
				animation-delay: -3s;
			}

			.bg-shape--3 {
				bottom: -7rem;
				left: 34%;
				width: 18rem;
				height: 18rem;
				background: rgba(164, 194, 184, 0.2);
				animation-delay: -1.5s;
			}

			.archive {
				position: relative;
				z-index: 1;
				width: min(1280px, 100%);
				margin: 0 auto;
				padding-top: 1.25rem;
			}

			.masthead {
				position: relative;
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 1.5rem;
				align-items: end;
				padding: 0.75rem 0 2rem;
			}

			.masthead-copy {
				position: relative;
			}

			.masthead-label {
				display: inline-flex;
				align-items: center;
				gap: 0.9rem;
				margin-bottom: 1rem;
				font-size: 0.78rem;
				letter-spacing: 0.32em;
				text-transform: uppercase;
				color: rgba(33, 48, 40, 0.58);
			}

			.masthead-label::before {
				content: '';
				width: 44px;
				height: 1px;
				background: currentColor;
			}

			.masthead-title {
				margin: 0;
				font-size: clamp(4rem, 14vw, 10rem);
				line-height: 0.84;
				letter-spacing: -0.09em;
				font-weight: 200;
				color: rgba(33, 48, 40, 0.94);
			}

			.masthead-title span {
				display: block;
				margin-left: 0.08em;
			}

			.masthead-ghost {
				position: absolute;
				top: -0.12em;
				right: 0.04em;
				font-size: clamp(4rem, 16vw, 14rem);
				line-height: 0.9;
				font-weight: 200;
				letter-spacing: -0.08em;
				color: rgba(126, 163, 140, 0.025);
				pointer-events: none;
				user-select: none;
			}

			.masthead-side {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 0.8rem;
				padding-bottom: 0.55rem;
			}

			.stat-pill {
				padding: 0.72rem 1rem;
				border-radius: 999px;
				border: 1px solid rgba(0, 0, 0, 0.05);
				background: rgba(255, 255, 255, 0.38);
				backdrop-filter: blur(14px);
				font-size: 0.76rem;
				letter-spacing: 0.28em;
				text-transform: uppercase;
				color: rgba(33, 48, 40, 0.68);
				white-space: nowrap;
				box-shadow: 0 10px 26px rgba(24, 34, 28, 0.04);
			}

			.feature {
				position: relative;
				margin-bottom: 1.1rem;
			}

			.feature-card {
				position: relative;
				display: grid;
				grid-template-columns: minmax(0, 1fr) 220px;
				gap: 1.5rem;
				min-height: 360px;
				padding: 2rem;
				border-radius: 36px;
				overflow: hidden;
				background:
					linear-gradient(135deg, rgba(255, 255, 255, 0.52), rgba(255, 255, 255, 0.2)),
					linear-gradient(180deg, rgba(126, 163, 140, 0.08), rgba(226, 218, 194, 0.08));
				border: 1px solid rgba(0, 0, 0, 0.05);
				backdrop-filter: blur(16px);
				box-shadow: 0 18px 48px rgba(31, 42, 36, 0.05);
				transition:
					transform 0.45s ease,
					box-shadow 0.45s ease,
					border-color 0.45s ease;
			}

			.feature-card:hover {
				transform: translateY(-6px);
				box-shadow: 0 26px 72px rgba(31, 42, 36, 0.1);
				border-color: rgba(0, 0, 0, 0.08);
			}

			.feature-card::before {
				content: '01';
				position: absolute;
				right: 1.6rem;
				bottom: -0.08em;
				font-size: clamp(6rem, 20vw, 14rem);
				line-height: 0.9;
				font-weight: 200;
				letter-spacing: -0.08em;
				color: rgba(33, 48, 40, 0.05);
				pointer-events: none;
			}

			.feature-card::after {
				content: '';
				position: absolute;
				top: 1.3rem;
				right: 1.3rem;
				width: 82px;
				height: 82px;
				border-radius: 999px;
				border: 1px solid rgba(126, 163, 140, 0.14);
				background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.3), transparent 65%);
				pointer-events: none;
			}

			.feature-main {
				position: relative;
				z-index: 1;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				min-width: 0;
			}

			.feature-meta {
				display: flex;
				align-items: center;
				gap: 0.8rem;
				flex-wrap: wrap;
				margin-bottom: 1.2rem;
				font-size: 0.76rem;
				letter-spacing: 0.24em;
				text-transform: uppercase;
				color: rgba(33, 48, 40, 0.62);
			}

			.feature-tag {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.5rem 0.75rem;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.5);
				border: 1px solid rgba(0, 0, 0, 0.05);
				box-shadow: 0 10px 24px rgba(24, 34, 28, 0.035);
			}

			.feature-dot {
				width: 5px;
				height: 5px;
				border-radius: 999px;
				background: #7ea38c;
			}

			.feature-title {
				margin: 0;
				max-width: 9.5em;
				font-family: 'Noto Serif SC', serif;
				font-size: clamp(2.2rem, 5vw, 4.6rem);
				line-height: 1.06;
				letter-spacing: 0.03em;
				font-weight: 400;
				text-wrap: balance;
			}

			.feature-bottom {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-top: 1.6rem;
			}

			.feature-line {
				width: 88px;
				height: 1px;
				background: linear-gradient(90deg, rgba(33, 48, 40, 0.62), transparent);
				transition: width 0.4s ease;
			}

			.feature-card:hover .feature-line {
				width: 132px;
			}

			.feature-read {
				font-size: 0.8rem;
				letter-spacing: 0.24em;
				text-transform: uppercase;
				color: rgba(33, 48, 40, 0.6);
			}

			.feature-side {
				position: relative;
				z-index: 1;
				display: flex;
				align-items: flex-start;
				justify-content: flex-end;
				padding-top: 0.2rem;
			}

			.feature-stack {
				display: flex;
				flex-direction: column;
				align-items: stretch;
				gap: 0.8rem;
				width: 100%;
			}

			.feature-chip {
				width: 100%;
				padding: 0.95rem 1rem;
				border-radius: 22px;
				border: 1px solid rgba(0, 0, 0, 0.05);
				background: rgba(255, 255, 255, 0.4);
				backdrop-filter: blur(14px);
				text-align: right;
				box-shadow: 0 12px 28px rgba(24, 34, 28, 0.04);
			}

			.feature-chip-label {
				display: block;
				margin-bottom: 0.3rem;
				font-size: 0.68rem;
				letter-spacing: 0.26em;
				text-transform: uppercase;
				color: rgba(33, 48, 40, 0.48);
			}

			.feature-chip-value {
				display: block;
				font-size: 1rem;
				letter-spacing: 0.12em;
				color: rgba(33, 48, 40, 0.84);
			}

			.entries {
				display: grid;
				grid-template-columns: repeat(12, minmax(0, 1fr));
				gap: 16px;
			}

			.entry {
				min-width: 0;
			}

			.entry--wide {
				grid-column: span 7;
			}

			.entry--tall {
				grid-column: span 5;
			}

			.entry--standard {
				grid-column: span 5;
			}

			.entry-link {
				position: relative;
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
				min-height: 250px;
				padding: 1.35rem 1.35rem 1.2rem;
				border-radius: 30px;
				overflow: hidden;
				background:
					linear-gradient(135deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.2)),
					linear-gradient(180deg, rgba(126, 163, 140, 0.06), rgba(226, 218, 194, 0.06));
				border: 1px solid rgba(0, 0, 0, 0.05);
				backdrop-filter: blur(14px);
				box-shadow: 0 14px 36px rgba(31, 42, 36, 0.045);
				opacity: 0;
				transform: translateY(24px);
				animation: rise 0.75s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
				transition:
					transform 0.45s ease,
					box-shadow 0.45s ease,
					border-color 0.45s ease;
			}

			.entry-link:hover {
				transform: translateY(-6px) !important;
				box-shadow: 0 22px 58px rgba(31, 42, 36, 0.09);
				border-color: rgba(0, 0, 0, 0.08);
			}

			.entry-link::before {
				content: attr(data-index);
				position: absolute;
				right: 1rem;
				bottom: -0.05em;
				font-size: clamp(4.2rem, 10vw, 7.5rem);
				line-height: 0.9;
				font-weight: 200;
				letter-spacing: -0.08em;
				color: rgba(33, 48, 40, 0.05);
				pointer-events: none;
			}

			.entry-link::after {
				content: '';
				position: absolute;
				top: 1rem;
				right: 1rem;
				width: 54px;
				height: 54px;
				border-radius: 999px;
				border: 1px solid rgba(126, 163, 140, 0.14);
				background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.24), transparent 70%);
				pointer-events: none;
			}

			.entry-top {
				position: relative;
				z-index: 1;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.8rem;
				margin-bottom: 1rem;
			}

			.entry-index {
				font-size: 0.72rem;
				letter-spacing: 0.26em;
				text-transform: uppercase;
				color: rgba(33, 48, 40, 0.52);
			}

			.entry-date {
				font-size: 0.72rem;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: rgba(33, 48, 40, 0.52);
			}

			.entry-title {
				position: relative;
				z-index: 1;
				margin: 0;
				max-width: 9em;
				font-family: 'Noto Serif SC', serif;
				font-size: clamp(1.4rem, 2.4vw, 2.2rem);
				line-height: 1.15;
				font-weight: 400;
				letter-spacing: 0.02em;
				text-wrap: balance;
			}

			.entry-bottom {
				position: relative;
				z-index: 1;
				display: flex;
				align-items: center;
				gap: 0.8rem;
				margin-top: auto;
				padding-top: 2rem;
			}

			.entry-dot {
				width: 7px;
				height: 7px;
				border-radius: 999px;
				background: #7ea38c;
				flex-shrink: 0;
			}

			.entry-line {
				width: 54px;
				height: 1px;
				background: linear-gradient(90deg, rgba(33, 48, 40, 0.56), transparent);
				transition: width 0.4s ease;
			}

			.entry-link:hover .entry-line {
				width: 100px;
			}

			.entry--tall .entry-link {
				min-height: 330px;
			}

			.entry--wide .entry-link {
				min-height: 250px;
			}

			.entry--wide .entry-title {
				font-size: clamp(1.6rem, 2.8vw, 2.6rem);
			}

			.empty {
				display: grid;
				place-items: center;
				min-height: 58vh;
				border-radius: 34px;
				background: rgba(255, 255, 255, 0.34);
				border: 1px solid rgba(0, 0, 0, 0.05);
				backdrop-filter: blur(14px);
				box-shadow: 0 16px 44px rgba(31, 42, 36, 0.04);
			}

			.empty h2 {
				margin: 0;
				font-family: 'Noto Serif SC', serif;
				font-size: 2rem;
				font-weight: 400;
			}

			@keyframes drift {
				from {
					transform: translate3d(0, 0, 0) scale(1);
				}
				to {
					transform: translate3d(4%, 5%, 0) scale(1.08);
				}
			}

			@keyframes rise {
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@media (max-width: 1080px) {
				.feature-card {
					grid-template-columns: 1fr;
					min-height: unset;
				}

				.feature-side {
					justify-content: flex-start;
					padding-top: 0;
				}

				.feature-stack {
					align-items: flex-start;
				}

				.feature-chip {
					width: min(280px, 100%);
					text-align: left;
				}

				.masthead {
					grid-template-columns: 1fr;
				}

				.masthead-side {
					align-items: flex-start;
				}

				.entry--wide,
				.entry--tall,
				.entry--standard {
					grid-column: span 6;
				}
			}

			@media (max-width: 760px) {
				.page {
					padding: 0 12px 28px;
				}

				.masthead {
					padding-bottom: 1.4rem;
				}

				.masthead-title {
					font-size: clamp(3.2rem, 18vw, 6rem);
				}

				.masthead-ghost {
					display: none;
				}

				.feature-card {
					padding: 1.35rem;
					border-radius: 24px;
				}

				.feature-title {
					max-width: 100%;
					font-size: clamp(1.9rem, 8vw, 3rem);
				}

				.feature-card::before {
					font-size: 7rem;
					right: 1rem;
				}

				.entries {
					grid-template-columns: 1fr;
				}

				.entry--wide,
				.entry--tall,
				.entry--standard {
					grid-column: auto;
				}

				.entry-link,
				.entry--tall .entry-link,
				.entry--wide .entry-link {
					min-height: 220px;
					border-radius: 24px;
				}

				.entry-title,
				.entry--wide .entry-title {
					max-width: 100%;
					font-size: clamp(1.4rem, 7vw, 2rem);
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<div class="page">
			<div class="bg-shape bg-shape--1"></div>
			<div class="bg-shape bg-shape--2"></div>
			<div class="bg-shape bg-shape--3"></div>

			<main class="archive">
				<section class="masthead">
					<div class="masthead-copy">
						<div class="masthead-label">Text Only Index</div>
						<div class="masthead-ghost" aria-hidden="true">NOTE</div>
						<h1 class="masthead-title">
							BLOG
							<span>ARCHIVE</span>
						</h1>
					</div>

					<div class="masthead-side">
						<div class="stat-pill">{posts.length} POSTS</div>
						<div class="stat-pill">{archiveYear}</div>
					</div>
				</section>

				{
					featuredPost ? (
						<>
							<section class="feature">
								<a class="feature-card" href={`/blog/${featuredPost.id}/`}>
									<div class="feature-main">
										<div>
											<div class="feature-meta">
												<span class="feature-tag">Latest</span>
												<span class="feature-dot"></span>
												<span>
													<FormattedDate date={featuredPost.data.pubDate} />
												</span>
											</div>

											<h2 class="feature-title">{featuredPost.data.title}</h2>
										</div>

										<div class="feature-bottom">
											<div class="feature-line"></div>
											<div class="feature-read">Read</div>
										</div>
									</div>

									<div class="feature-side">
										<div class="feature-stack">
											<div class="feature-chip">
												<span class="feature-chip-label">Entry</span>
												<span class="feature-chip-value">01</span>
											</div>
											<div class="feature-chip">
												<span class="feature-chip-label">Type</span>
												<span class="feature-chip-value">Essay / Note</span>
											</div>
										</div>
									</div>
								</a>
							</section>

							{
								restPosts.length > 0 && (
									<section class="entries">
										{restPosts.map((post, index) => (
											<article class={`entry ${getVariant(index)}`}>
												<a
													class="entry-link"
													href={`/blog/${post.id}/`}
													data-index={String(index + 2).padStart(2, '0')}
													style={`animation-delay:${0.08 + index * 0.06}s;`}
												>
													<div class="entry-top">
														<div class="entry-index">
															{String(index + 2).padStart(2, '0')}
														</div>
														<div class="entry-date">
															<FormattedDate date={post.data.pubDate} />
														</div>
													</div>

													<h3 class="entry-title">{post.data.title}</h3>

													<div class="entry-bottom">
														<div class="entry-dot"></div>
														<div class="entry-line"></div>
													</div>
												</a>
											</article>
										))}
									</section>
								)
							}
						</>
					) : (
						<section class="empty">
							<h2>还没有文章</h2>
						</section>
					)
				}
			</main>
		</div>
	</body>
</html>